<!DOCTYPE html>
<html lang="fr-FR" dir="ltr" class="htmlPublic">
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="author" content="Vrecq Nathalie - Codèvea">
        <meta name="publisher" content="Codèvea">
        <meta name="copyright" content="Vrecq Nathalie - Codèvea">
        <title>
            {% block title %}
                Bienvenue 
            {% endblock %}
        </title>

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
