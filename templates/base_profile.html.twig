<!DOCTYPE html>
<html lang="fr-FR" dir="ltr" class="htmlProfile">
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="author" content="Vrecq Nathalie - Codèvea">
        <meta name="publisher" content="Codèvea">
        <meta name="copyright" content="Vrecq Nathalie - Codèvea">
        <title>
            {% block title %}
                Administration professionnel
            {% endblock %}
        </title>

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}
                {{ importmap('app') }}
            {% endblock %}
        {% endblock %}

        <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96">
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        <link rel="shortcut icon" href="/favicon.ico">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <meta name="apple-mobile-web-app-title" content="chienchat">
        <link
        rel="manifest" href="/site.webmanifest">

  </head>
    <body class="bodyProfile">
        <header>
            {% include '_partials/_navone.html.twig' %}
        </header>
        <article>
            <h1>Tableau d'administration profesionnel</h1>
            <div class="containerDashboardProfile">
                <div class="contenuLeftProfile">
                    {% include "profile/_partials/_nav_profile.html.twig" %}
                </div>
                <div class="contenuRightProfile">
                    <div class="conteneurHeaderProfile">
                        <div class="textBold">
                            <div>
                                {% block contenuText %}
                                    Activité professionnel
                                {% endblock %}
                            </div>
                            <div class="textLinear">
                                {% block contenuTextLinear %}
                                {% endblock %}
                            </div>
                        </div>
                    </div>
                    {% include "_partials/_flash_message.html.twig" %}
                    {% block body %}
                    {% endblock %}
                </div>
            </div>
        </article>
    </body>
</html>
