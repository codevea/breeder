<div {{ attributes }}>
    {{ form_start(form) }}

    {% if form_errors(form) %}
        <div class="error">
            {{ form_errors(form) }}
        </div>
    {% endif %}

    {{ form_row(form.addAffixe) }}

    {% if form.affixe is defined %}
        {{ form_row(form.affixe) }}
    {% endif %}

    {% if form.raceCat is defined %}
        {{ form_row(form.raceCat) }}
    {% endif %}

    {% if form.raceDog is defined %}
        {{ form_row(form.raceDog) }}
    {% endif %}

    {% if form.submit is defined %}
        {{ form_row(form.submit) }}
    {% endif %}

    {{ form_end(form) }}
</div>