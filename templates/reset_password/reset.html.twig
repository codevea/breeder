{% extends 'base.html.twig' %}

{% block htmlClass %}
    htmlPublic
{% endblock %}

{% block bodyClass %}
    bodyPublic
{% endblock %}

{% block headerClass %}
    headerPublic
{% endblock %}

{% block footerClass %}
    footerPublic
{% endblock %}

{% block title %}
    Réinitialiser votre mot de passe
{% endblock %}

{% block body %}
    <div class="sectionForm">
        <div>
            <h3>Réinitialiser votre mot de passe</h3>
        </div>
        <div>
            {{ form_start(resetForm) }}
            {{ form_row(resetForm.plainPassword) }}
            {{ form_row(resetForm.submit) }}
            {{ form_end(resetForm) }}
        </div>
    </div>
{% endblock %}
